.title-container {
  width: 100%;
  background-color: transparent;
  z-index: 10;
}

.title-container h1 {
  display: flex;
  justify-content: center;
  text-align: center;
}

.title-container h1 .title-container-border-icon {
  width: 80px;
  height: 80px;
  border-width: 5px;
  border-style: solid;
  border-color: #333;
  border-radius: 50%;
  background-color: transparent;
  display: flex;
  justify-content: center;
  align-items: center;
}

.title-container h1 .title-container-icon {
  width: 70px;
  height: 50px;
}

.title-container h2 {
  text-align: center;
  font-size: 2rem;
  margin: 2px 0px 2px 0px;
}

.title-container h3 {
  text-align: center;
  font-size: 1.4rem;
  /* margin: 5px 0px; */
}

.title-container p {
  text-align: center;
  font-size: 1.3rem;
  margin-bottom: 5px;
}

.success-changed-container .social-text {
  padding: 0.7rem 0;
  font-size: 1rem;
  text-align: center;
}
