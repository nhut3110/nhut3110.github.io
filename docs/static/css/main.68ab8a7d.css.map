.modal__searchBox {
  position: fixed;
  background: rgba(0, 0, 0, 0.7);
  inset: 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal__searchBox-box {
  width: 33%;
  height: auto;
  background-color: #fff;
  padding: 20px 15px;
  border: 10px;
  border-radius: 10px;
}

.modal__searchBox-header {
  display: flex;
  justify-content: space-between;
  /* align-items: center; */
}

.btn__close {
  margin-top: -20px;
  font-size: 1.4rem;
  font-weight: 600;
  cursor: pointer;
}

.searchBox__container {
  width: 95%;
  padding: 5px;
}

.searchBox__container .searchBox__input {
  width: 100%;
  height: 30px;
  padding: 0px 10px;
  font-size: 1.1rem;
  border-radius: 5px;
  font-weight: 600;
  margin-bottom: 20px;
}

.searchBox__singleResult {
  width: 100%;
  max-height: 30px;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 0px 5px 10px 5px;
  margin: 10px 0px;
  border-bottom: #333 1px solid;
}

.searchBox__singleResult .searchBox__singleResult-todo {
  display: flex;
  max-width: 60%;
}

.searchBox__singleResult .searchBox__singleResult-todo input {
  margin: 0px 5px;
  width: 20px;
  aspect-ratio: 1/1;
  pointer-events: none;
  accent-color: #333;
}

.searchBox__singleResult-name {
  color: black;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 1.2rem;
}

.searchBox__singleResult a {
  font-size: 0.9rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-decoration: none;
  color: gray;
}
