.title-container {
  width: 100%;
  background-color: transparent;
  z-index: 10;
}

.title-container h1 {
  display: flex;
  justify-content: center;
  text-align: center;
}

.title-container h1 .title-container-border-icon {
  width: 80px;
  height: 80px;
  border-width: 5px;
  border-style: solid;
  border-color: #333;
  border-radius: 50%;
  background-color: transparent;
  display: flex;
  justify-content: center;
  align-items: center;
}

.title-container h1 .title-container-icon {
  width: 45px;
  height: 45px;
}

.title-container h2 {
  text-align: center;
  font-size: 2rem;
  margin: 5px 0px;
}

.email-notification-container {
  flex-direction: column;
  position: relative;
  vertical-align: middle;
  display: flex;
}

.email-notification-container .notification-box {
  border: 2px solid black;
  border-radius: 10px;
  width: 400px;
  height: 100px;
  display: block;
  margin: auto;
}

.email-notification-container .notification-content {
  font-size: 1.2rem;
  text-align: center;
  padding: 10px;
}

.email-notification-container .resent-email-text {
  font-size: 1rem;
  text-align: center;
  margin-top: 5px;
  height: 5vh;
}

.email-notification-container .social-text {
  text-align: center;
  margin-top: -5px;
}
